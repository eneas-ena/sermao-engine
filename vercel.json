{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/analyze.py": {
      "maxDuration": 120
    },
    "api/export.py": {
      "maxDuration": 120
    },
    "api/pptx.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/static/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
